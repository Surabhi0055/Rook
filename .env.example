
# ── API / Backend ─────────────────────────────────────────────
API_BASE_URL=http://localhost:8000

HOST=0.0.0.0
PORT=8000


# ── Database ──────────────────────────────────────────────────
# SQLite (development):
DATABASE_URL=sqlite+aiosqlite:///./rook.db
# PostgreSQL (production — uncomment and fill in):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rook


# ── JWT / Auth tokens ─────────────────────────────────────────
# Generate a strong random value: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-here-change-me

# Algorithm used for JWT signing (HS256 is the most common)
JWT_ALGORITHM=HS256

# Access token expiry in minutes (e.g. 60 = 1 hour)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiry in days
REFRESH_TOKEN_EXPIRE_DAYS=7


# ── Google OAuth ──────────────────────────────────────────────
# Get these from https://console.cloud.google.com/
# APIs & Services → Credentials → Create OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret


# ── CORS / Frontend origin ────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Development: leave as localhost ports
# Production: set to your real domain, e.g. https://rook.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5500


# ── Recommender / ML ──────────────────────────────────────────
MODEL_PATH=./models
DATA_PATH=./data

# Number of recommendations returned by default
DEFAULT_TOP_N=20

# Local Ollama LLM model to use for query expansion
ROOK_LLM_MODEL=llama3.2:3b

# Optional — Google Books API key for cover/description enrichment
# Get from https://console.cloud.google.com/ → APIs & Services → Library → Books API
GOOGLE_BOOKS_API_KEY=


# ── Environment ───────────────────────────────────────────────
# "development" | "production" | "testing"
ENVIRONMENT=development

# Set to true to enable verbose SQL and API logging (disable in production)
DEBUG=false


# ── Email (Gmail + App Password) ─────────────────────────────
# Used for OTP-based forgot-password flow
# Generate app password at: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password


# ── Spotify ───────────────────────────────────────────────────
# Get from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
